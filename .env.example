NODE_ENV="development"
APP_NAME="Knitto Nest API"
APP_VERSION="0.1.0"
HOST="0.0.0.0"
PORT="3333"
GLOBAL_PREFIX="api"
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_ENABLED="true"
OPENAPI_APP_NAME="app name"
OPENAPI_APP_DESCRIPTION="project app description"
