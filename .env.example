POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
POSTGRES_DB="db"
POSTGRES_PORT="5432"
LOG_PRISMA="true"
BETTER_AUTH_URL="http://localhost:3333"
BETTER_AUTH_SECRET=""
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@yourdomain.com"
