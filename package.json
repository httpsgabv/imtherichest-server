{
  "name": "nest-api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "ISC",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:init": "prisma migrate dev --name init",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "docker:db": "docker compose up postgres",
    "docker:db:down": "docker compose down",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "openapi:generate": "pnpm build && node dist/src/infra/generate-openapi.js",
    "prepare": "husky",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.mts",
    "test:watch": "vitest watch",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@better-auth/infra": "^0.2.8",
    "@better-auth/prisma-adapter": "^1.6.10",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@scalar/nestjs-api-reference": "^1.1.14",
    "@sentry/nestjs": "^10.51.0",
    "@thallesp/nestjs-better-auth": "^2.6.0",
    "better-auth": "^1.6.10",
    "dotenv": "^17.4.2",
    "helmet": "^8.1.0",
    "nestjs-pino": "4.6.1",
    "nestjs-zod": "^5.3.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.3",
    "rxjs": "^7.8.1",
    "unplugin-swc": "^1.5.9",
    "vite-tsconfig-paths": "^6.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@faker-js/faker": "^10.4.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "pino-pretty": "13.1.3",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^4.1.5"
  },
  "main": "index.js",
  "keywords": [],
  "imports": {
    "#infra/*": "./dist/src/infra/*",
    "#setup/*": "./dist/src/setup/*",
    "#common/*": "./dist/src/common/*",
    "#domain/*": "./dist/src/domain/*",
    "#core/*": "./dist/src/core/*",
    "#lib/*": "./dist/src/lib/*",
    "#test/*": "./test/*",
    "#generated/*": "./dist/generated/*"
  }
}
